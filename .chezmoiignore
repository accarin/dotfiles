# .chezmoiignore — interpreted as a template
# Logic is INVERTED: list what to IGNORE (not what to include)

# Never deploy the README to the home dir
README.md

# --- Wayland / window manager configs ---
# Only deploy on non-server machines (workstation, gaming, notebook)
{{- if eq .machine_type "server" }}
.config/niri
.config/waybar
.config/wofi
.config/mako
.config/hypr
{{- end }}

# --- Gaming-only configs ---
# Ignore on everything except gaming
{{- if ne .machine_type "gaming" }}
.config/gamemode
.config/mangohud
.config/environment.d/10-gamescope-session.conf
.local/share/lutris
{{- end }}

# --- Server-only configs ---
# Ignore on everything except server
{{- if ne .machine_type "server" }}
.config/server-motd
{{- end }}

# --- Shell: deploy the right shell config ---
# Server + wsl use bash, desktops (workstation/gaming/notebook) use fish
{{- if not (or (eq .machine_type "server") (eq .machine_type "wsl")) }}
dot_bashrc
{{- end }}
{{- if or (eq .machine_type "server") (eq .machine_type "wsl") }}
.config/fish
{{- end }}
# Ignore Starship on server + wsl
{{- if or (eq .machine_type "server") (eq .machine_type "wsl") }}
.config/starship
{{- end }}

