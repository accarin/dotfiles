{{/* chezmoi:modify-template */}}
{{- /* --------------------------------------------------------
     VS Code's User settings.json is actively rewritten by both
     the user (Settings UI) and VS Code itself (theme picks,
     survey-prompt timestamps, extension state, etc). Rather than
     manage the whole file, parse the existing JSON (stripping //
     comments first, since settings.json is JSONC and Go's
     encoding/json can't handle comments) and merge our overrides
     in, so everything else survives every "chezmoi apply".
     -------------------------------------------------------- */ -}}

{{- $existing := .chezmoi.stdin }}
{{- $cleaned := regexReplaceAll "(?m)^[ \t]*//.*$" $existing "" }}

{{- $data := dict }}
{{- if ne (trim $cleaned) "" }}
{{-   $data = $cleaned | fromJson }}
{{- end }}

{{- $data = mergeOverwrite $data (dict
      "terminal.integrated.automationProfile.linux" (dict "path" "/usr/bin/bash")
      "terminal.integrated.defaultProfile.linux" "bash"
    ) -}}
// This file is managed by chezmoi (dot_config/Code/User/modify_settings.json
// in the dotfiles repo). All your other settings are preserved as-is; only
// the key(s) below are enforced on every "chezmoi apply":
//
//   terminal.integrated.automationProfile.linux
//     Forces bash (not fish) for automation terminals -- the ones VS Code
//     tasks/debug configs and Copilot's agent tool use to run shell
//     commands -- while leaving terminal.integrated.defaultProfile.linux
//     (fish) untouched for terminals you open yourself. Fixes Copilot
//     getting confused by fish syntax when it writes bash-style commands.
//     Override per-project via that project's own .vscode/settings.json
//     with the same key, which takes precedence over this user setting.
//
//   terminal.integrated.defaultProfile.linux
//     TEMPORARY WORKAROUND (added 2026-07-22): automationProfile above is
//     currently NOT honored by the chat "run in terminal" tool -- confirmed
//     by testing (fresh terminals still spawn fish even after a full VS
//     Code restart with automationProfile correctly set). Matches known
//     upstream bug: https://github.com/microsoft/vscode/issues/309502
//     ("RunInTerminalTool ignores automationProfile"). Until that's fixed,
//     also forcing the INTERACTIVE default shell to bash here, trading away
//     fish in every VS Code terminal (not just automation ones) to stop
//     Copilot wasting tokens on fish/bash syntax confusion. Revert this key
//     (leave automationProfile in place) once #309502 is fixed upstream.
{{ $data | toPrettyJson }}
