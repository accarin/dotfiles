# =============================================================================
# ~/.zshrc — server config
# Managed by chezmoi
# =============================================================================

# PATH
export PATH="$HOME/.local/bin:$PATH"

# Environment
export EDITOR=nvim
export PAGER=less

# Prompt (simple, no starship dep on servers)
autoload -Uz promptinit
promptinit
prompt walters

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS

# Aliases
alias ll='ls -lah --color=auto'
alias la='ls -A --color=auto'
alias ..='cd ..'
alias cm=chezmoi
alias cmu='chezmoi update -v'
alias cmt='chezmoi apply --dry-run --verbose'
alias cma='chezmoi apply -v'
alias cmd='chezmoi diff'