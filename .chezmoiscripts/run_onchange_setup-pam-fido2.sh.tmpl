#!/bin/bash
# run_onchange_setup-pam-fido2.sh.tmpl
set -euo pipefail

{{- $origin := .u2f.origin }}
{{- $appid  := .u2f.appid }}

{{- /* --------------------------------------------------------
     Resolve per-machine overrides
     -------------------------------------------------------- */ -}}

{{- $u2f_enabled := .u2f.enabled }}
{{- $u2f_keys := .u2f_keys }}

{{- $hostname := .chezmoi.hostname }}
{{- if hasKey .machines $hostname }}
{{-   $machine := index .machines $hostname }}

{{-   if hasKey $machine "u2f" }}
{{-     $machineU2f := index $machine "u2f" }}
{{-     if hasKey $machineU2f "enabled" }}
{{-       $u2f_enabled = index $machineU2f "enabled" }}
{{-     end }}
{{-   end }}

{{-   if hasKey $machine "u2f_keys" }}
{{-     $u2f_keys = index $machine "u2f_keys" }}
{{-   end }}

{{- end }}

{{- if and (ne .machine_type "server") $u2f_enabled }}

echo "==> Deploying /etc/u2f_mappings..."
sudo install -m 600 -o root -g root /dev/stdin /etc/u2f_mappings << 'EOF'
{{ range $user, $data := $u2f_keys -}}
{{ $user }}:{{ join ":" $data.keys }}
{{ end -}}
EOF

echo "==> Deploying PAM system-auth..."
sudo install -m 644 -o root -g root /dev/stdin /etc/pam.d/system-auth << 'EOF'
#%PAM-1.0

auth       required                    pam_faillock.so      preauth
-auth      [success=3 default=ignore]  pam_systemd_home.so
auth       [success=2 default=ignore]  pam_u2f.so           authfile=/etc/u2f_mappings cue pinverification=1 origin={{ $origin }} appid={{ $appid }}
auth       [success=1 default=bad]     pam_unix.so          try_first_pass nullok
auth       [default=die]               pam_faillock.so      authfail
auth       optional                    pam_permit.so
auth       required                    pam_env.so
auth       required                    pam_faillock.so      authsucc

-account   [success=1 default=ignore]  pam_systemd_home.so
account    required                    pam_unix.so
account    optional                    pam_permit.so
account    required                    pam_time.so

-password  [success=1 default=ignore]  pam_systemd_home.so
password   required                    pam_unix.so          try_first_pass nullok shadow
password   optional                    pam_permit.so

-session   optional                    pam_systemd_home.so
session    required                    pam_limits.so
session    required                    pam_unix.so
session    optional                    pam_permit.so
EOF

echo "==> Deploying PAM noctalia..."
sudo install -m 644 -o root -g root /dev/stdin /etc/pam.d/noctalia << 'EOF'
#%PAM-1.0

auth       required                    pam_faillock.so      preauth
-auth      [success=3 default=ignore]  pam_systemd_home.so
auth       [success=2 default=ignore]  pam_u2f.so           authfile=/etc/u2f_mappings cue origin={{ $origin }} appid={{ $appid }}
auth       [success=1 default=bad]     pam_unix.so          try_first_pass nullok
auth       [default=die]               pam_faillock.so      authfail
auth       optional                    pam_permit.so
auth       required                    pam_env.so
auth       required                    pam_faillock.so      authsucc

account    include                     system-auth
password   include                     system-auth
session    include                     system-auth
EOF

echo "==> PAM FIDO2 setup complete."

{{- else }}

echo "==> FIDO2 PAM setup skipped (not enabled for {{ $hostname }})."

{{- end }}