#!/bin/bash
# run_onchange_setup-dot.sh.tmpl
set -euo pipefail

{{- $dns_server_ip := .dot.dns_server_ip }}
{{- $dns_suffix := .dot.dns_suffix }}
{{- $dashboard_url := .dot.dashboard_url }}
{{- $dns_fallback_ip_1 := .dot.dns_fallback_ip_1 }}
{{- $dns_fallback_ip_2 := .dot.dns_fallback_ip_2 }}
{{- $dns_fallback_1 := .dot.dns_fallback_1 }}
{{- $dns_fallback_2 := .dot.dns_fallback_2 }}

{{- /* --------------------------------------------------------
     Resolve per-machine overrides
     -------------------------------------------------------- */ -}}

{{- $dot_enabled := .dot.enabled }}
{{- $client_id := "" }}
{{- $interface_match := "enp*" }}

{{- $hostname := .chezmoi.hostname }}
{{- if hasKey .machines $hostname }}
{{-   $machine := index .machines $hostname }}

{{-   if hasKey $machine "dot" }}
{{-     $machineDot := index $machine "dot" }}
{{-     if hasKey $machineDot "enabled" }}
{{-       $dot_enabled = index $machineDot "enabled" }}
{{-     end }}
{{-     if hasKey $machineDot "client_id" }}
{{-       $client_id = index $machineDot "client_id" }}
{{-     end }}
{{-     if hasKey $machineDot "interface_match" }}
{{-       $interface_match = index $machineDot "interface_match" }}
{{-     end }}
{{-   end }}

{{- end }}

{{- if not $dot_enabled }}

echo "==> DNS-over-TLS setup skipped (not enabled for {{ $hostname }})."

{{- else if eq $client_id "" }}

echo "==> DNS-over-TLS is enabled for {{ $hostname }} but no clientId is configured." >&2
echo "==> A per-machine clientId is required so AdGuard can identify/whitelist" >&2
echo "==> this machine's DNS-over-TLS queries. Nothing has been deployed." >&2
echo "==>" >&2
echo "==> Suggested clientId (24 random lowercase letters/digits, from /dev/urandom):" >&2
echo "==>   $(tr -dc 'a-z0-9' < /dev/urandom | head -c24)" >&2
echo "==>" >&2
echo "==> 1. Register this clientId in the AdGuard dashboard and add it to the" >&2
echo "==>    whitelist: {{ $dashboard_url }}" >&2
echo "==> 2. Add it to .chezmoidata.toml:" >&2
echo "==>      [machines.{{ $hostname }}.dot]" >&2
echo "==>      enabled   = true" >&2
echo "==>      client_id = \"<clientId-from-above>\"" >&2
echo "==> 3. Re-run 'chezmoi apply'." >&2
exit 1

{{- else }}

echo "==> Deploying /etc/systemd/resolved.conf.d/dot.conf..."
DOT_CONF_PATH="/etc/systemd/resolved.conf.d/dot.conf"
DOT_CONF_OLD_HASH=""
if [ -f "$DOT_CONF_PATH" ]; then
  DOT_CONF_OLD_HASH=$(sha256sum "$DOT_CONF_PATH" | awk '{print $1}')
fi

sudo install -Dm644 /dev/stdin "$DOT_CONF_PATH" << 'EOF'
[Resolve]
DNS={{ $dns_server_ip }}#{{ $client_id }}.{{ $dns_suffix }} {{ $dns_fallback_ip_1 }}#{{ $dns_fallback_1 }} {{ $dns_fallback_ip_2 }}#{{ $dns_fallback_2 }}
DNSOverTLS=yes
Domains=~.
Cache=yes
EOF

DOT_CONF_NEW_HASH=$(sha256sum "$DOT_CONF_PATH" | awk '{print $1}')

if [ "$DOT_CONF_OLD_HASH" != "$DOT_CONF_NEW_HASH" ]; then
  echo "==> Configuration changed, restarting systemd-resolved..."
  sudo systemctl restart systemd-resolved
else
  echo "==> Configuration unchanged, skipping restart."
fi

echo "==> Deploying /etc/NetworkManager/conf.d/dns-override.conf..."
# DHCP-provided DNS servers otherwise get merged/preferred ahead of the
# DNS-over-TLS config above, silently breaking it. This drop-in stops
# NetworkManager from letting DHCP touch resolv.conf/systemd-resolved for
# matching devices (wired interfaces matching $interface_match, plus any
# WiFi device unconditionally).
NM_CONF_PATH="/etc/NetworkManager/conf.d/dns-override.conf"
NM_CONF_OLD_HASH=""
if [ -f "$NM_CONF_PATH" ]; then
  NM_CONF_OLD_HASH=$(sha256sum "$NM_CONF_PATH" | awk '{print $1}')
fi

sudo install -Dm644 /dev/stdin "$NM_CONF_PATH" << 'EOF'
[connection-dns-override]
match-device=interface-name:{{ $interface_match }};type:wifi
ipv4.ignore-auto-dns=true
ipv6.ignore-auto-dns=true
EOF

NM_CONF_NEW_HASH=$(sha256sum "$NM_CONF_PATH" | awk '{print $1}')

if [ "$NM_CONF_OLD_HASH" != "$NM_CONF_NEW_HASH" ]; then
  echo "==> Configuration changed, restarting NetworkManager..."
  sudo systemctl restart NetworkManager
else
  echo "==> Configuration unchanged, skipping restart."
fi

if command -v docker &>/dev/null; then

  echo "==> Docker detected, ensuring DNS fallback in /etc/docker/daemon.json..."
  # Docker's embedded DNS proxy ignores loopback nameservers (e.g.
  # systemd-resolved's 127.0.0.53 stub) and silently falls back to public
  # DNS unless "dns" is set explicitly here -- so containers need their own
  # explicit fallback resolvers, independent of the host's DoT setup.
  if ! command -v jq &>/dev/null; then
    echo "==> Installing jq..."
    {{- if or (eq .machine_type "server") (eq .machine_type "wsl") }}
    sudo apt-get install -y jq
    {{- else }}
    sudo pacman -S --needed --noconfirm jq
    {{- end }}
  fi

  DAEMON_JSON_PATH="/etc/docker/daemon.json"
  if [ -f "$DAEMON_JSON_PATH" ]; then
    DAEMON_JSON_OLD_CONTENT=$(sudo cat "$DAEMON_JSON_PATH")
  else
    DAEMON_JSON_OLD_CONTENT="{}"
  fi
  DAEMON_JSON_OLD_HASH=$(printf '%s' "$DAEMON_JSON_OLD_CONTENT" | sha256sum | awk '{print $1}')

  DAEMON_JSON_NEW_CONTENT=$(printf '%s' "$DAEMON_JSON_OLD_CONTENT" | jq --arg d1 "{{ $dns_fallback_ip_1 }}" --arg d2 "{{ $dns_fallback_ip_2 }}" '.dns = [$d1, $d2]')
  DAEMON_JSON_NEW_HASH=$(printf '%s' "$DAEMON_JSON_NEW_CONTENT" | sha256sum | awk '{print $1}')

  if [ "$DAEMON_JSON_OLD_HASH" != "$DAEMON_JSON_NEW_HASH" ]; then
    echo "==> Configuration changed, updating daemon.json and restarting Docker..."
    printf '%s\n' "$DAEMON_JSON_NEW_CONTENT" | sudo install -Dm644 /dev/stdin "$DAEMON_JSON_PATH"
    sudo systemctl restart docker
  else
    echo "==> Configuration unchanged, skipping restart."
  fi

else
  echo "==> Docker not detected, skipping daemon.json DNS fallback."
fi

echo "==> DNS-over-TLS setup complete."

{{- end }}
