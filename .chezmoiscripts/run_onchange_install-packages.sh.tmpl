#!/bin/bash
# run_onchange_install-packages.sh.tmpl
# Re-runs only when this file's content changes (i.e., when you edit the package list)
# Managed by chezmoi

set -euo pipefail

{{- if or (eq .machine_type "server") (eq .machine_type "wsl") }}

# ============================================================
# SERVER / WSL — Debian packages
# ============================================================
DEBIAN_PKGS=(
    bash-completion
    git
    curl
    wget
    htop
    tmux
    micro
    nano
    ripgrep
    fd-find
    fzf
    zoxide
    bat
    eza
    unzip
    tree
    jq
)

echo "==> Installing Debian packages..."
sudo apt-get update -qq
sudo apt-get install -y "${DEBIAN_PKGS[@]}"

# Set bash as the default login shell (servers/wsl only — coadmins have
# their own accounts, this only ever touches the user chezmoi runs as)
if [ "$(getent passwd "$USER" | cut -d: -f7)" != "$(command -v bash)" ]; then
    chsh -s "$(command -v bash)"
fi

{{- else }}

# ============================================================
# DESKTOP — CachyOS / Arch packages (pacman + paru for AUR)
# ============================================================

PACMAN_PKGS=(
    # Shell & terminal
    kitty
    fish
    starship
    foot
    tmux

    # Editors & tools
    neovim
    git
    curl
    wget
    ripgrep
    fd
    fzf
    bat
    eza
    zoxide
    jq
    unzip
    tree

    # Wayland / desktop
    # niri
    # waybar
    # wofi
    # mako
    # wl-clipboard
    # xdg-utils
    # pipewire
    # wireplumber

    # Utilties
    bolt

    # Fonts
    ttf-jetbrains-mono-nerd
)

AUR_PKGS=(
    # AUR packages common to all desktops
    # Add yours here
)

{{-   if eq .machine_type "gaming" }}
PACMAN_PKGS+=(
    steam
    gamemode
    gamescope
    gamescope-session-cachyos
    mangohud
    lib32-mangohud
    wine
    winetricks
    lutris
    vulkan-tools
)

AUR_PKGS+=(
    proton-ge-custom
)
{{-   end }}

{{-   if eq .machine_type "notebook" }}
PACMAN_PKGS+=(
    brightnessctl
    tlp
    powertop
    acpi
)
{{-   end }}

echo "==> Installing pacman packages..."
sudo pacman -S --needed --noconfirm "${PACMAN_PKGS[@]}"

if command -v paru &>/dev/null && [ ${#AUR_PKGS[@]} -gt 0 ]; then
    echo "==> Installing AUR packages via paru..."
    paru -S --needed --noconfirm "${AUR_PKGS[@]}"
fi

# Set fish as default shell (desktops only)
if ! grep -q "$(which fish)" /etc/shells; then
    echo "$(which fish)" | sudo tee -a /etc/shells
fi
if [ "$SHELL" != "$(which fish)" ]; then
    chsh -s "$(which fish)"
fi

{{- end }}

echo "==> Package installation complete."